# Nome do banco de dados SQLite (sem extensao).
# Se vazio, o app busca qualquer *.db na pasta raiz ou permite selecionar via UI.
DB_NAME=financeiro_crm

# Pasta onde os bancos sao armazenados (relativo a raiz do app)
DB_DIR=.

# Pasta para comprovantes de imagem
IMG_DIR=comprovantes

# Pasta para relatorios PDF
PDF_DIR=relatorios
